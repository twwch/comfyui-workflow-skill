{
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "wan2.2_t2v_14b.safetensors",
      "weight_dtype": "default"
    },
    "_meta": { "title": "Load Wan 2.2 Model" }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "umt5_xxl_fp16.safetensors",
      "clip_name2": "open_clip_vit_h.safetensors",
      "type": "wan"
    },
    "_meta": { "title": "Load CLIP (Wan)" }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "wan_2.2_vae.safetensors"
    },
    "_meta": { "title": "Load VAE" }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "a cat playing with a ball in a sunny garden, smooth motion, high quality",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Positive Prompt" }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "worst quality, blurry, distorted, static, watermark",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Negative Prompt" }
  },
  "6": {
    "class_type": "WanImageToVideo",
    "inputs": {
      "positive": ["4", 0],
      "negative": ["5", 0],
      "vae": ["3", 0],
      "width": 832,
      "height": 480,
      "length": 81,
      "batch_size": 1
    },
    "_meta": { "title": "Wan Text-to-Video Conditioning" }
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["6", 0],
      "negative": ["6", 1],
      "latent_image": ["6", 2],
      "seed": 0,
      "steps": 25,
      "cfg": 6.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0
    },
    "_meta": { "title": "KSampler" }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7", 0],
      "vae": ["3", 0]
    },
    "_meta": { "title": "VAE Decode" }
  },
  "9": {
    "class_type": "SaveAnimatedWEBP",
    "inputs": {
      "images": ["8", 0],
      "filename_prefix": "ComfyUI_Wan_T2V",
      "fps": 16.0,
      "lossless": false,
      "quality": 85,
      "method": "default"
    },
    "_meta": { "title": "Save Video (WEBP)" }
  }
}
