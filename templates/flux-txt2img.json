{
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux1-dev.safetensors",
      "weight_dtype": "default"
    },
    "_meta": { "title": "Load FLUX Model" }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5xxl_fp16.safetensors",
      "type": "flux"
    },
    "_meta": { "title": "Load CLIP (FLUX)" }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    },
    "_meta": { "title": "Load VAE" }
  },
  "4": {
    "class_type": "CLIPTextEncodeFlux",
    "inputs": {
      "clip": ["2", 0],
      "clip_l": "a beautiful woman in a garden",
      "t5xxl": "a beautiful woman standing in a lush garden with blooming flowers, soft natural lighting, photorealistic, high detail",
      "guidance": 3.5
    },
    "_meta": { "title": "FLUX Text Encode (Positive)" }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "_meta": { "title": "Empty Latent" }
  },
  "6": {
    "class_type": "BasicGuider",
    "inputs": {
      "model": ["1", 0],
      "conditioning": ["4", 0]
    },
    "_meta": { "title": "Basic Guider" }
  },
  "7": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    },
    "_meta": { "title": "Sampler Select" }
  },
  "8": {
    "class_type": "BasicScheduler",
    "inputs": {
      "model": ["1", 0],
      "scheduler": "simple",
      "steps": 20,
      "denoise": 1.0
    },
    "_meta": { "title": "Scheduler" }
  },
  "9": {
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": 0
    },
    "_meta": { "title": "Random Noise" }
  },
  "10": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["9", 0],
      "guider": ["6", 0],
      "sampler": ["7", 0],
      "sigmas": ["8", 0],
      "latent_image": ["5", 0]
    },
    "_meta": { "title": "Advanced Sampler" }
  },
  "11": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["10", 0],
      "vae": ["3", 0]
    },
    "_meta": { "title": "VAE Decode" }
  },
  "12": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["11", 0],
      "filename_prefix": "ComfyUI_FLUX"
    },
    "_meta": { "title": "Save Image" }
  }
}
