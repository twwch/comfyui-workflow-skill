{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "sdxl_model.safetensors"
    },
    "_meta": { "title": "Load SDXL Checkpoint" }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "masterpiece, best quality, a stunning landscape with mountains and lake, golden hour lighting",
      "clip": ["1", 1]
    },
    "_meta": { "title": "Positive Prompt" }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "worst quality, low quality, blurry, deformed, ugly",
      "clip": ["1", 1]
    },
    "_meta": { "title": "Negative Prompt" }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "_meta": { "title": "Empty Latent (SDXL)" }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": 0,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "euler",
      "scheduler": "karras",
      "denoise": 1.0
    },
    "_meta": { "title": "KSampler" }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    },
    "_meta": { "title": "VAE Decode" }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "ComfyUI_SDXL"
    },
    "_meta": { "title": "Save Image" }
  }
}
