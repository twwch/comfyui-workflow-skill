{
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "hunyuan_video.safetensors",
      "weight_dtype": "default"
    },
    "_meta": { "title": "Load HunyuanVideo Model" }
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "llava_llama3_fp16.safetensors",
      "type": "wan"
    },
    "_meta": { "title": "Load CLIP" }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "hunyuan_video_vae_bf16.safetensors"
    },
    "_meta": { "title": "Load VAE" }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "a person walking through a beautiful forest, sunlight filtering through trees, cinematic quality, smooth motion",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Positive Prompt" }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "worst quality, blurry, distorted",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Negative Prompt" }
  },
  "6": {
    "class_type": "EmptyHunyuanLatentVideo",
    "inputs": {
      "width": 848,
      "height": 480,
      "length": 25,
      "batch_size": 1
    },
    "_meta": { "title": "Empty HunyuanVideo Latent" }
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0],
      "seed": 0,
      "steps": 30,
      "cfg": 6.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0
    },
    "_meta": { "title": "KSampler" }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7", 0],
      "vae": ["3", 0]
    },
    "_meta": { "title": "VAE Decode" }
  },
  "9": {
    "class_type": "SaveAnimatedWEBP",
    "inputs": {
      "images": ["8", 0],
      "filename_prefix": "ComfyUI_HunyuanVideo",
      "fps": 24.0,
      "lossless": false,
      "quality": 85,
      "method": "default"
    },
    "_meta": { "title": "Save Video (WEBP)" }
  }
}
